:80 {
    root * /usr/share/nginx/html
    encode gzip

    handle_path /api/* {
        reverse_proxy http://backend:8000 {
            transport http {
                response_header_timeout 30s
                dial_timeout 5s
            }
        }
    }

    handle {
        try_files {path} {path}/ /index.html
        file_server
    }
}